@startuml AI管理模块接口

interface "IAIManager" {
  ' 发送消息，触发流式 AI 回复
  + sendMessage(sessionId: String, userMessage: String): void
  ' 中止当前正在生成的回复
  + stopGeneration(): void
  ' 设置系统提示词（人格 / 记忆注入）
  + setSystemPrompt(prompt: String): void
  ' 切换使用的 AI 模型
  + setModel(model: String): void
  ' 配置 Anthropic API Key
  + setApiKey(key: String): void
}

note right of IAIManager
  信号（Qt signal）:
  - tokenReceived(token: String)     ' 流式接收每个 token
  - replyFinished(fullReply: String) ' 回复完整结束
  - errorOccurred(error: String)     ' 请求出错（网络/鉴权等）
end note

@enduml
