@startuml 持久化模块接口

' Repository 模式：通过统一接口抽象存储后端，上层无需关心具体存储方式

' ─────────────────────────────────────────
' 核心泛型 Repository 接口
' ─────────────────────────────────────────
interface "IRepository<T>" as IRepository {
    + load(id: String) : T
    + save(id: String, data: T) : void
    + remove(id: String) : void
    + exists(id: String) : bool
    + listIds() : List<String>
}

' ─────────────────────────────────────────
' 文件存储抽象层
' ─────────────────────────────────────────
interface IFileRepository {
    + readRaw(path: String) : ByteArray
    + writeRaw(path: String, data: ByteArray) : void
    + deleteFile(path: String) : void
    + fileExists(path: String) : bool
    + listFiles(dir: String, filter: String) : List<String>
}

IRepository <|-- IFileRepository

' ─────────────────────────────────────────
' 各格式文件 Repository
' ─────────────────────────────────────────
interface IMarkdownRepository {
    + readMarkdown(path: String) : String
    + writeMarkdown(path: String, content: String) : void
    + extractFrontMatter(path: String) : Map<String, String>
}

interface IJsonRepository {
    + readJson(path: String) : JsonObject
    + writeJson(path: String, obj: JsonObject) : void
    + readJsonArray(path: String) : JsonArray
}

interface IXmlRepository {
    + readXml(path: String) : XmlDocument
    + writeXml(path: String, doc: XmlDocument) : void
    + query(path: String, xpath: String) : XmlNodeList
}

interface IIniRepository {
    + readValue(path: String, section: String, key: String) : String
    + writeValue(path: String, section: String, key: String, value: String) : void
    + readSection(path: String, section: String) : Map<String, String>
    + listSections(path: String) : List<String>
}

IFileRepository <|-- IMarkdownRepository
IFileRepository <|-- IJsonRepository
IFileRepository <|-- IXmlRepository
IFileRepository <|-- IIniRepository

' ─────────────────────────────────────────
' 数据库 Repository（预留扩展）
' ─────────────────────────────────────────
interface IDbRepository {
    + connect(connectionString: String) : void
    + disconnect() : void
    + query(sql: String, params: List<Any>) : ResultSet
    + execute(sql: String, params: List<Any>) : int
    + beginTransaction() : void
    + commit() : void
    + rollback() : void
}

IRepository <|-- IDbRepository

' ─────────────────────────────────────────
' 工厂：根据配置创建对应 Repository
' ─────────────────────────────────────────
interface IRepositoryFactory {
    + createMarkdownRepo() : IMarkdownRepository
    + createJsonRepo() : IJsonRepository
    + createXmlRepo() : IXmlRepository
    + createIniRepo() : IIniRepository
    + createDbRepo(type: String) : IDbRepository
}

' ─────────────────────────────────────────
' 关系总览
' ─────────────────────────────────────────
IRepositoryFactory ..> IMarkdownRepository : creates
IRepositoryFactory ..> IJsonRepository : creates
IRepositoryFactory ..> IXmlRepository : creates
IRepositoryFactory ..> IIniRepository : creates
IRepositoryFactory ..> IDbRepository : creates

note top of IRepository
  泛型 T 由业务层决定（如 ChatRecord、Config、Memo）
  存储后端对上层透明
end note

note right of IDbRepository
  预留扩展：SQLite / MySQL / PostgreSQL
  当前版本不实现，接口先占位
end note

@enduml
